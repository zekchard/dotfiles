{
    "custom/arch": {
        "format": "пҒ“",
        "tooltip": true,
        "tooltip-format": "Tray"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 12
    },
    "group/hardware": {
	"orientation": "horizontal",
    "drawer": {
        "transition-duration": 500,
        "children-class": "not-power",
        "transition-left-to-right": false,
        "click-to-reveal": true
    },
	"modules": [
                "custom/arch",
		"tray",
		"idle_inhibitor"
	]
    },
    "cava": {
            // "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
            "framerate": 15,
            "autosens": 0,
            "sensitivity": 25,
            "bars": 16,
            "sample_rate": 44100,
            "lower_cutoff_freq": 100,
            "higher_cutoff_freq": 10000,
            "sleep_timer": 2,
            "hide_on_silence": true,
            "format_silent": " ",
            "method": "pipewire",
            "source": "auto",
            "stereo": true,
            "reverse": false,
            "bar_delimiter": 0,
            "bar_spacing": 12,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.15,
            "input_delay": 0,
            "format-icons": ["в Җ", "в Җ", "вЈҖ", "вЈӨ", "вЈӨ", "вЈ¶", "вЈҝ"],
            "actions": {
                       "on-click-right": "mode"
                       }
        },
     "hyprland/window": {
            "max-length": 64,
            "icon": false,
            "icon-size": 12,
            "format": "{title}",
            "format-alt": "{class}",
        },
    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "warp-on-scroll": true,
        "show-special": true,
        "format": "{name}{icon}",
        "format-icons": {
            "urgent": " пҒӘ",
            "active": "",
            "default": ""
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пҒ®",
            "deactivated": "пҒ°"
        }
    },
    "wireplumber": {
        "format": "{icon}{volume}%",
        "format-muted": "пҡ© ",
        "format-source": "п„° {volume}%",
        "format-source-muted": "п„ұ",
        "format-icons": ["пҖҰ ", "пҖ§ ", "пҖЁ "],
        "on-click": "pwvucontrol"
    },
    "network": {
	"interval": 2,
        "format": "пҮ« {bandwidthTotalBytes}",
        // "format-ethernet": "пһ–  п…¶ {bandwidthUpBytes} | {bandwidthDownBytes} пҒЈ",
        "tooltip-format": "{ifname} via {essid} пһ–",
        // "format-linked": "{ifname} (No IP) пһ–",
        "format-alt": "пҮ« п…¶ {bandwidthUpBytes} | {bandwidthDownBytes} пҒЈ",
        "format-disconnected": "Disconnected вҡ ",
	"on-click-right": "airctl",
	"on-click-middle": "nmtui"
	 
    },
    "cpu": {
        "interval": 2,
        "format": "пӢӣ {usage}%",
        "format-alt": "пӢӣ {usage}% | {avg_frequency} GHz",
        "tooltip": true
    },
    "memory": {
	"interval": 2,
        "format": "пғү {percentage}%",
        "format-alt": "пғү {used:0.1f}G/{total:0.1f}G",
	"tooltip": true
    },
    "temperature": {
        "interval": 2,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
        "critical-threshold": 95,
        "warning-threshold": 85,
        "format": "пӢү {temperatureC}В°C"
    },
    "hyprland/language": {
       "format": "пӮ¬  {}",
       "format-en": "EN",
       "format-ru": "RU"
    },
    "battery": {
    "states": {
    	"warning": 20,
    	"critical": 15
    },
	"interval": 5,
        "format": "{icon} {capacity}%   пғ§ {power} W",
        "format-full": "{icon} {capacity}%   пғ§ {power} W",
        "format-charging": "пҮҰ {capacity}%   пғ§ {power} W",
        "format-plugged": "пҮҰ {capacity}%   пғ§ {power} W",
        "format-alt": "{icon} {time}   пғ§ {power} W",
        "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
    },
    "clock": {
    	"interval": 1,
        "format": "{:%I:%M %p | %b %e %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%I:%M:%OS %p} "
    },
	"custom/srstatus": {
	    "exec": "~/.config/waybar/scripts/srstatus.sh",
	    "restart-interval": 1,
	},
	"custom/notification": {
	  "tooltip": true,
	  "format": "<span size='10pt'>{icon}</span>  {0}",
	  "format-icons": {
	    "notification": "уұ…«",
	    "none": "у°Ӯң",
	    "dnd-notification": "у°Ӯ ",
	    "dnd-none": "у°Ә“",
	    "inhibited-notification": "у°Ӯӣ",
	    "inhibited-none": "у°Ә‘",
	    "dnd-inhibited-notification": "у°Ӯӣ",
	    "dnd-inhibited-none": "у°Ә‘"
	  },
	  "restart-interval": 5,
	  "return-type": "json",
	  "exec-if": "which swaync-client",
	  "exec": "swaync-client -swb",
	  "on-click": "swaync-client -t -sw",
	  "on-click-right": "swaync-client -d -sw",
	  "escape": true
	},
}
