{
    "custom/arch": {
        "format": "яБУ",
        "tooltip": true,
        "tooltip-format": "Tray"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 12
    },
    "group/hardware": {
	"orientation": "horizontal",
    "drawer": {
        "transition-duration": 500,
        "children-class": "not-power",
        "transition-left-to-right": false,
        "click-to-reveal": true
    },
	"modules": [
                "custom/arch",
		"tray",
		"idle_inhibitor"
	]
    },
    "cava": {
            // "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
            "framerate": 15,
            "autosens": 1,
            "sensitivity": 0.5,
            "bars": 16,
            "sample_rate": 44100,
            "lower_cutoff_freq": 100,
            "higher_cutoff_freq": 10000,
            "sleep_timer": 2,
            "hide_on_silence": true,
            "format_silent": " ",
            "method": "pulse",
            "source": "auto",
            "stereo": true,
            "reverse": false,
            "bar_delimiter": 0,
            "bar_spacing": 12,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.15,
            "input_delay": 2,
            "format-icons": ["таА", "таА", "тгА", "тгд", "тгд", "тг╢", "тг┐"],
            "actions": {
                       "on-click-right": "mode"
                       }
        },
     "hyprland/window": {
            "max-length": 64,
        },
    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "warp-on-scroll": true,
        "format": "{name}{icon}",
        "format-icons": {
            "urgent": " яБк ",
            "active": "",
            "default": ""
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "яЪй ",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": ["яАж ", "яАз ", "яАи "],
        "on-click": "pwvucontrol"
    },
    "network": {
	"interval": 2,
        "format": "яЗл   {bandwidthTotalBytes}",
        // "format-ethernet": "яЮЦ  яЕ╢ {bandwidthUpBytes} | {bandwidthDownBytes} яБг",
        "tooltip-format": "{ifname} via {essid} яЮЦ",
        // "format-linked": "{ifname} (No IP) яЮЦ",
        "format-alt": "яЗл  яЕ╢ {bandwidthUpBytes} | {bandwidthDownBytes} яБг",
        "format-disconnected": "Disconnected тЪа",
	"on-click-right": "alacritty -T NetworkManager -e nmtui"
	 
    },
    "cpu": {
        "interval": 2,
        "format": "яЛЫ  {usage}%",
        "format-alt": "яЛЫ  {usage}% | {avg_frequency} GHz",
        "tooltip": true
    },
    "memory": {
	"interval": 2,
        "format": "яГЙ  {percentage}%",
        "format-alt": "яГЙ  {used:0.1f}G/{total:0.1f}G",
	"tooltip": true
    },
    "temperature": {
        "interval": 2,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
        "critical-threshold": 100,
        "format-critical": "яЛЗ {temperatureC}",
        "format": "яЛЙ {temperatureC}┬░C"
    },
    "hyprland/language": {
       "format": "яВм  {}",
       "format-en": "EN",
       "format-ru": "RU"
    },
    "battery": {
	"interval": 5,
        "format": "{icon}   {capacity}%  яГз  {power} W",
        "format-full": "{icon}   {capacity}%  яГз  {power} W",
        "format-charging": "яЧз  {capacity}%  яГз  {power} W",
        "format-plugged": "яЗж  {capacity}%  яГз  {power} W",
        "format-alt": "{icon}   {time}  яГз  {power} W",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
    	"interval": 1,
        "format": "{:%I:%M %p | %b %e %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%I:%M:%OS %p} "
    },
	"custom/srstatus": {
	    "exec": "~/.config/waybar/scripts/srstatus.sh",
	    "restart-interval": 1,
	},
}
