{
    "custom/arch": {
        "format": "",
        "tooltip": true,
        "tooltip-format": "Tray"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 12
    },
    "group/hardware": {
	"orientation": "horizontal",
    "drawer": {
        "transition-duration": 500,
        "children-class": "not-power",
        "transition-left-to-right": false,
        "click-to-reveal": true
    },
	"modules": [
                "custom/arch",
		"tray",
		"idle_inhibitor"
	]
    },
    "cava": {
            // "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
            "framerate": 15,
            "autosens": 0,
            "sensitivity": 25,
            "bars": 16,
            "sample_rate": 44100,
            "lower_cutoff_freq": 100,
            "higher_cutoff_freq": 10000,
            "sleep_timer": 2,
            "hide_on_silence": true,
            "format_silent": " ",
            "method": "pipewire",
            "source": "auto",
            "stereo": true,
            "reverse": false,
            "bar_delimiter": 0,
            "bar_spacing": 12,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.15,
            "input_delay": 0,
            "format-icons": ["⠀", "⠀", "⣀", "⣤", "⣤", "⣶", "⣿"],
            "actions": {
                       "on-click-right": "mode"
                       }
        },
     "hyprland/window": {
            "max-length": 64,
        },
    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "warp-on-scroll": true,
        "show-special": true,
        "format": "{name}{icon}",
        "format-icons": {
            "urgent": " ",
            "active": "",
            "default": ""
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    "wireplumber": {
        "format": "{icon}{volume}%",
        "format-muted": " ",
        "format-source": " {volume}%",
        "format-source-muted": "",
        "format-icons": [" ", " ", " "],
        "on-click": "pwvucontrol"
    },
    "network": {
	"interval": 2,
        "format": " {bandwidthTotalBytes}",
        // "format-ethernet": "   {bandwidthUpBytes} | {bandwidthDownBytes} ",
        "tooltip-format": "{ifname} via {essid} ",
        // "format-linked": "{ifname} (No IP) ",
        "format-alt": "  {bandwidthUpBytes} | {bandwidthDownBytes} ",
        "format-disconnected": "Disconnected ⚠",
	"on-click-right": "airctl",
	"on-click-middle": "nmtui"
	 
    },
    "cpu": {
        "interval": 2,
        "format": " {usage}%",
        "format-alt": " {usage}% | {avg_frequency} GHz",
        "tooltip": true
    },
    "memory": {
	"interval": 2,
        "format": " {percentage}%",
        "format-alt": " {used:0.1f}G/{total:0.1f}G",
	"tooltip": true
    },
    "temperature": {
        "interval": 2,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
        "critical-threshold": 100,
        "format-critical": " {temperatureC}",
        "format": " {temperatureC}°C"
    },
    "hyprland/language": {
       "format": "  {}",
       "format-en": "EN",
       "format-ru": "RU"
    },
    "battery": {
	"interval": 5,
        "format": "{icon} {capacity}%    {power} W",
        "format-full": "{icon} {capacity}%    {power} W",
        "format-charging": " {capacity}%    {power} W",
        "format-plugged": " {capacity}%    {power} W",
        "format-alt": "{icon} {time}    {power} W",
        "format-icons": ["", "", "", "", ""]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
    	"interval": 1,
        "format": "{:%I:%M %p | %b %e %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%I:%M:%OS %p} "
    },
	"custom/srstatus": {
	    "exec": "~/.config/waybar/scripts/srstatus.sh",
	    "restart-interval": 1,
	},
	"custom/notification": {
	  "tooltip": true,
	  "format": "<span size='10pt'>{icon}</span>  {0}",
	  "format-icons": {
	    "notification": "󱅫",
	    "none": "󰂜",
	    "dnd-notification": "󰂠",
	    "dnd-none": "󰪓",
	    "inhibited-notification": "󰂛",
	    "inhibited-none": "󰪑",
	    "dnd-inhibited-notification": "󰂛",
	    "dnd-inhibited-none": "󰪑"
	  },
	  "restart-interval": 5,
	  "return-type": "json",
	  "exec-if": "which swaync-client",
	  "exec": "swaync-client -swb",
	  "on-click": "swaync-client -t -sw",
	  "on-click-right": "swaync-client -d -sw",
	  "escape": true
	},
}
