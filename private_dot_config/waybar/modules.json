{
    "custom/arch": {
        "format": "´üô",
        "tooltip": true,
        "tooltip-format": "Tray"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 12
    },
    "group/hardware": {
	"orientation": "horizontal",
    "drawer": {
        "transition-duration": 500,
        "children-class": "not-power",
        "transition-left-to-right": false,
        "click-to-reveal": true
    },
	"modules": [
                "custom/arch",
		"tray",
		"idle_inhibitor"
	]
    },
    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "warp-on-scroll": true,
        "format": "{name}",
        "format-icons": {
            "urgent": "´ü¬",
            "active": "´åÆ",
            "default": "´äæ"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "´Ü® ",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒",
        "format-icons": ["´Çª ", "´Çº ", "´Ç¿ "],
        "on-click": "pwvucontrol"
    },
    "network": {
	"interval": 2,
        "format": "´ç½   {bandwidthTotalBytes}",
        // "format-ethernet": "´×û  ´àÂ {bandwidthUpBytes} | {bandwidthDownBytes} ´üú",
        "tooltip-format": "{ifname} via {essid} ´×û",
        // "format-linked": "{ifname} (No IP) ´×û",
        "format-alt": "´ç½  ´àÂ {bandwidthUpBytes} | {bandwidthDownBytes} ´üú",
        "format-disconnected": "Disconnected ÔÜá",
	"on-click-right": "alacritty -T NetworkManager -e nmtui"
	 
    },
    "cpu": {
        "interval": 2,
        "format": "´ïø  {usage}%",
        "format-alt": "´ïø  {usage}% | {avg_frequency} GHz",
        "tooltip": true
    },
    "memory": {
	"interval": 2,
        "format": "´âë  {percentage}%",
        "format-alt": "´âë  {used:0.1f}G/{total:0.1f}G",
	"tooltip": true
    },
    "temperature": {
        "interval": 2,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
        "critical-threshold": 100,
        "format-critical": "´ïç {temperatureC}",
        "format": "´ïë {temperatureC}┬░C"
    },
    "hyprland/language": {
       "format": "´é¼  {}",
       "format-en": "EN",
       "format-ru": "RU"
    },
    "battery": {
	"interval": 5,
        "format": "{icon}   {capacity}%  ´âº  {power} W",
        "format-full": "{icon}   {capacity}%  ´âº  {power} W",
        "format-charging": "´ùº  {capacity}%  ´âº  {power} W",
        "format-plugged": "´çª  {capacity}%  ´âº  {power} W",
        "format-alt": "{icon}   {time}  ´âº  {power} W",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
    	"interval": 1,
        "format": "{:%I:%M %p | %b %e %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%I:%M:%OS %p} "
    },
	"custom/srstatus": {
	    "exec": "~/.config/waybar/scripts/srstatus.sh",
	    "restart-interval": 1,
	},
}
