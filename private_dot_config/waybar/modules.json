{
    "custom/arch": {
        "format": "пЃ“",
        "tooltip": true,
        "tooltip-format": "Tray"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 12
    },
    "group/hardware": {
	"orientation": "horizontal",
    "drawer": {
        "transition-duration": 500,
        "children-class": "not-power",
        "transition-left-to-right": false,
        "click-to-reveal": true
    },
	"modules": [
                "custom/arch",
		"tray",
		"idle_inhibitor"
	]
    },
    "cava": {
            // "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
            "framerate": 15,
            "autosens": 0,
            "sensitivity": 50,
            "bars": 16,
            "sample_rate": 44100,
            "lower_cutoff_freq": 100,
            "higher_cutoff_freq": 10000,
            "sleep_timer": 2,
            "hide_on_silence": true,
            "format_silent": " ",
            "method": "pulse",
            "source": "auto",
            "stereo": true,
            "reverse": false,
            "bar_delimiter": 0,
            "bar_spacing": 12,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.15,
            "input_delay": 2,
            "format-icons": ["в Ђ", "в Ђ", "вЈЂ", "вЈ¤", "вЈ¤", "вЈ¶", "вЈї"],
            "actions": {
                       "on-click-right": "mode"
                       }
        },
     "hyprland/window": {
            "max-length": 64,
        },
    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "warp-on-scroll": true,
        "format": "{name}{icon}",
        "format-icons": {
            "urgent": "пЃЄ ",
            "active": "",
            "default": ""
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пЃ®",
            "deactivated": "пЃ°"
        }
    },
    "pulseaudio": {
        "format": "{icon}{volume}%",
        "format-muted": "пљ© ",
        "format-source": "п„° {volume}%",
        "format-source-muted": "п„±",
        "format-icons": ["пЂ¦ ", "пЂ§ ", "пЂЁ "],
        "on-click": "pwvucontrol"
    },
    "network": {
	"interval": 2,
        "format": "п‡« {bandwidthTotalBytes}",
        // "format-ethernet": "пћ–  п…¶ {bandwidthUpBytes} | {bandwidthDownBytes} пЃЈ",
        "tooltip-format": "{ifname} via {essid} пћ–",
        // "format-linked": "{ifname} (No IP) пћ–",
        "format-alt": "п‡« п…¶ {bandwidthUpBytes} | {bandwidthDownBytes} пЃЈ",
        "format-disconnected": "Disconnected вљ ",
	"on-click-right": "airctl",
	"on-click-middle": "nmtui"
	 
    },
    "cpu": {
        "interval": 2,
        "format": "п‹› {usage}%",
        "format-alt": "п‹› {usage}% | {avg_frequency} GHz",
        "tooltip": true
    },
    "memory": {
	"interval": 2,
        "format": "пѓ‰ {percentage}%",
        "format-alt": "пѓ‰ {used:0.1f}G/{total:0.1f}G",
	"tooltip": true
    },
    "temperature": {
        "interval": 2,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
        "critical-threshold": 100,
        "format-critical": "п‹‡ {temperatureC}",
        "format": "п‹‰ {temperatureC}В°C"
    },
    "hyprland/language": {
       "format": "п‚¬  {}",
       "format-en": "EN",
       "format-ru": "RU"
    },
    "battery": {
	"interval": 5,
        "format": "{icon} {capacity}%   пѓ§ {power} W",
        "format-full": "{icon} {capacity}%   пѓ§ {power} W",
        "format-charging": "п—§ {capacity}%   пѓ§ {power} W",
        "format-plugged": "п‡¦ {capacity}%   пѓ§ {power} W",
        "format-alt": "{icon} {time}   пѓ§ {power} W",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
    	"interval": 1,
        "format": "{:%I:%M %p | %b %e %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%I:%M:%OS %p} "
    },
	"custom/srstatus": {
	    "exec": "~/.config/waybar/scripts/srstatus.sh",
	    "restart-interval": 1,
	},
	"custom/notification": {
	  "tooltip": true,
	  "format": "<span size='10pt'>{icon}</span>  {0}",
	  "format-icons": {
	    "notification": "у±…«",
	    "none": "у°‚њ",
	    "dnd-notification": "у°‚ ",
	    "dnd-none": "у°Є“",
	    "inhibited-notification": "у°‚›",
	    "inhibited-none": "у°Є‘",
	    "dnd-inhibited-notification": "у°‚›",
	    "dnd-inhibited-none": "у°Є‘"
	  },
	  "restart-interval": 5,
	  "return-type": "json",
	  "exec-if": "which swaync-client",
	  "exec": "swaync-client -swb",
	  "on-click": "swaync-client -t -sw",
	  "on-click-right": "swaync-client -d -sw",
	  "escape": true
	},
}
