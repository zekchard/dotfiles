{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "cssPriority": "user",
  "control-center-margin-top": 7,
  "control-center-margin-bottom": 7,
  "control-center-margin-right": 7,
  "control-center-margin-left": 7,
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-icon-size": 64,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "relative-timestamps": true,
  "control-center-width": 500,
  "control-center-height": 600,
  "notification-window-width": 500,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "No Notifications",
  "script-fail-notify": true,
  "scripts": {
    "example-script": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    },
    "example-action-script": {
      "exec": "echo 'Do something actionable!'",
      "urgency": "Normal",
      "run-on": "action"
    }
  },
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },
  "widgets": [
    "menubar",
    "mpris",
    "volume",
    "backlight",
    "inhibitors",
    "title",
    "notifications",
    "dnd",
    "buttons-grid"
  ],
  "widget-config": {
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "󰎟",
      "clear-all-button": true
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": true,
      "show-per-app-label": true,
      "show-per-app-icon": false
    },
    "backlight": {
      "label": "󰃠",
      "device": "amdgpu_bl0"
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰎟"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "label": {
      "max-lines": 5,
      "text": "Label Text"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 5,
      "blacklist": []
    },
    "menubar": {
      "menu#powermode-buttons": {
        "label": "󰓅", 
        "position": "right",
        "actions": [ 
          {
            "label": "Performance",
            "command": "cpupower-gui pr Performance && swaync-client -cp && swayosd-client --custom-message 'CPU in Performance governor'"
          },
          {
            "label": "Ondemand",
            "command": "cpupower-gui pr Ondemand && swaync-client -cp && swayosd-client --custom-message 'CPU in Ondemand governor'"
          },
          {
            "label": "Limit to 1696Mhz",
            "command": "cpupower-gui pr yuhhhhhh && swaync-client -cp && swayosd-client --custom-message 'CPU limited to 1.7GHz'"
          }
        ]
      },
      "menu#power-buttons": {
        "label": "", 
        "position": "right",
        "actions": [ 
          {
            "label": "   Reboot",
            "command": "systemctl reboot"
          },
          {
            "label": "   Lock",
            "command": "swaylock.sh"
          },
          {
            "label": "   Logout",
            "command": "loginctl terminate-session ${XDG_SESSION_ID-}"
          },
          {
            "label": "   Shut down",
            "command": "systemctl poweroff"
          }
        ]
      },
      "menu#screenshot-buttons": {
        "label": "",
        "position": "left",
        "actions": [
          {
            "label": "   Entire screen",
            "command": "swaync-client -cp && sleep 1 && pkill hyprshot & hyprshot -m active -m output -o ~/Pictures/Screenshots -z"
          },
          {
            "label": "󱣴   Select a region",
            "command": "swaync-client -cp && sleep 1 && pkill hyprshot & hyprshot -m region -o ~/Pictures/Screenshots -z"
          },          {
            "label": "󱣴   Select a window",
            "command": "swaync-client -cp && sleep 1 && pkill hyprshot & hyprshot -m window -o ~/Pictures/Screenshots -z"
          },
          
          {
            "label": "󰉋   Open screenshot folder",
            "command": "xdg-open ~/Pictures/Screenshots"
          }
        ]
      },
      "menu#screencast-buttons": {
        "label": "",
        "position": "left",
        "actions": [
          {
            "label": "   Entire screen",
            "command": "swaync-client -cp && sleep 1 && /home/zek/scripts/screenrec.sh record"
          },
          {
            "label": "   Select a region",
            "command": "swaync-client -cp && sleep 1 && /home/zek/scripts/screenrec.sh region"
          },
          {
            "label": "   Stop",
            "command": "swaync-client -cp && /home/zek/scripts/screenrec.sh end"
          },
          {
            "label": "   Open screencast folder",
            "command": "xdg-open ~/Videos/Screencasts"
          }
        ]
      }
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰤨",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
          "update-command": "sh -c '[[ $(nmcli radio wifi) == \"enabled\" ]] && echo true || echo false'"
        },
        {
          "label": "󰂯",
          "command": "blueberry"
        },
        {
          "label": "",
          "type": "toggle",
          "active": true,
          "command": "/home/zek/.config/hypr/scripts/gamemode.sh",
          "update-command": "/home/zek/.config/swaync/gamemodewatch.sh"
        },
        {
          "label": "󰉋",
          "command": "nautilus"
        },
        {
          "label": "",
          "command": "waterfox"
        }
      ]
    }
  }
}
